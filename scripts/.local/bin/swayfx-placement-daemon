#!/usr/bin/env python3
"""SwayFX floating-window placement and border policy daemon."""

# Verified against: https://github.com/altdesktop/i3ipc-python, sway-ipc(7)
# Reviewed: 2026-06-10

from __future__ import annotations

import sys
import time
from typing import Iterable, Optional

try:
    import i3ipc
except ImportError:
    print(
        "swayfx-placement-daemon: python-i3ipc is not installed "
        "(pacman -S python-i3ipc)",
        file=sys.stderr,
    )
    raise SystemExit(1)


CASCADE_STEP = 25
SIDE_MARGIN = 80
DEFAULT_FLOATING_BORDER = 3
DEFAULT_WINDOW_WIDTH = 1280
DEFAULT_WINDOW_HEIGHT = 720
MAXIMIZE_MARK = "maximize"

# Anything at or below this size is treated as a dialog/confirmation
# popup: sway already centers it (over its parent for transient
# windows), so the cascade must not relocate it. Wayland toplevels do
# not expose their parent in the tree, so size is the only reliable
# signal; X11 windows additionally expose transient_for.
DIALOG_MAX_WIDTH = 700
DIALOG_MAX_HEIGHT = 500

# App IDs / WM classes that should be auto-maximized when they open.
AUTO_MAXIMIZE_APP_IDS = frozenset({
    "brave-browser",
    "brave",
    "brave-origin",
    "brave-origin-beta",
    "brave-origin-nightly",
})
AUTO_MAXIMIZE_WM_CLASSES = frozenset({
    "brave-browser",
    "brave-origin",
    "brave-origin-beta",
    "brave-origin-nightly",
})


class CascadeState:
    def __init__(self) -> None:
        self.index = 0


state = CascadeState()


def walk(con) -> Iterable:
    yield con
    for child in getattr(con, "nodes", []) or []:
        yield from walk(child)
    for child in getattr(con, "floating_nodes", []) or []:
        yield from walk(child)


def find_by_id(root, con_id: int):
    for con in walk(root):
        if getattr(con, "id", None) == con_id:
            return con
    return None


def is_window(con) -> bool:
    return bool(getattr(con, "window", None) or getattr(con, "app_id", None))


def is_floating(con) -> bool:
    return str(getattr(con, "floating", "")).endswith("_on")


def has_mark(con, mark: str) -> bool:
    return mark in (getattr(con, "marks", None) or [])


def is_dialog(con) -> bool:
    props = getattr(con, "ipc_data", {}).get("window_properties") or {}
    if props.get("transient_for"):
        return True
    rect = getattr(con, "rect", None)
    if rect is None:
        return False
    return (
        0 < rect.width <= DIALOG_MAX_WIDTH
        and 0 < rect.height <= DIALOG_MAX_HEIGHT
    )


def should_auto_maximize(con) -> bool:
    app_id = (getattr(con, "app_id", None) or "").lower()
    wm_class = ((getattr(con, "window_properties", None) or {}).get("class") or "").lower()
    return app_id in AUTO_MAXIMIZE_APP_IDS or wm_class in AUTO_MAXIMIZE_WM_CLASSES


def workspace_for(con, conn):
    try:
        ws = con.workspace()
        if ws is not None:
            return ws
    except Exception:
        pass
    focused = conn.get_tree().find_focused()
    return focused.workspace() if focused else None


def full_window_area(conn, con) -> Optional[tuple[int, int, int, int]]:
    """Area under the top bar, ignoring gaps: x, y, width, height.

    ws.rect excludes both the waybar exclusive zone and the workspace
    gaps. Assuming uniform gaps (left == right == bottom), the gap is
    ws.x - out.x, and the bar height is the rest of the top offset.
    """
    ws = workspace_for(con, conn)
    if ws is None:
        return None
    out = None
    for o in conn.get_outputs():
        if o.active and o.rect.x <= ws.rect.x < o.rect.x + o.rect.width \
                and o.rect.y <= ws.rect.y < o.rect.y + o.rect.height:
            out = o
            break
    if out is None:
        return None
    gap = max(ws.rect.x - out.rect.x, 0)
    bar = max(ws.rect.y - out.rect.y - gap, 0)
    return out.rect.x, out.rect.y + bar, out.rect.width, out.rect.height - bar


def maximize_window(conn, con) -> None:
    area = full_window_area(conn, con)
    if area is None:
        return
    x, y, w, h = area
    # border none must precede resize/move: sway compensates any active
    # border when sizing/positioning, which left a 3px offset ring.
    con.command(
        f"floating enable, border none, shadows disable, "
        f"mark --add {MAXIMIZE_MARK}, "
        f"resize set {w} {h}, "
        f"move absolute position {x} {y}"
    )


def safe_position_for(con, conn) -> Optional[tuple[int, int]]:
    ws = workspace_for(con, conn)
    if ws is None:
        return None

    rect = ws.rect
    width = max(getattr(con.rect, "width", 0) or DEFAULT_WINDOW_WIDTH, 1)
    height = max(getattr(con.rect, "height", 0) or DEFAULT_WINDOW_HEIGHT, 1)

    min_x = rect.x + SIDE_MARGIN
    min_y = rect.y + SIDE_MARGIN
    max_x = rect.x + rect.width - SIDE_MARGIN - width
    max_y = rect.y + rect.height - SIDE_MARGIN - height

    if max_x < min_x:
        max_x = min_x
    if max_y < min_y:
        max_y = min_y

    x = min_x + (state.index * CASCADE_STEP)
    y = min_y + (state.index * CASCADE_STEP)

    if x > max_x or y > max_y:
        state.index = 0
        x = min_x
        y = min_y

    state.index += 1
    return x, y


def place_floating_window(conn, con) -> None:
    pos = safe_position_for(con, conn)
    if pos is None:
        return
    x, y = pos
    con.command(f"move absolute position {x} {y}")


def visible_workspace_windows(ws) -> list:
    if ws is None:
        return []
    return [con for con in walk(ws) if is_window(con)]


def set_border(con, style: str) -> None:
    current = getattr(con, "border", "")
    current_width = getattr(con, "current_border_width", -1)

    if style == "none":
        if current != "none" or current_width != 0:
            con.command("border none")
        return

    if current != "pixel" or current_width != DEFAULT_FLOATING_BORDER:
        con.command(f"border pixel {DEFAULT_FLOATING_BORDER}")


def update_borders(conn, tree=None) -> None:
    if tree is None:
        tree = conn.get_tree()
    focused = tree.find_focused()
    if focused is None:
        return

    ws = focused.workspace()
    windows = visible_workspace_windows(ws)
    visible_count = len(windows)

    for con in windows:
        if not is_floating(con):
            continue
        if has_mark(con, MAXIMIZE_MARK) or getattr(con, "fullscreen_mode", 0):
            set_border(con, "none")
        elif visible_count == 1 and getattr(con, "id", None) == getattr(focused, "id", None):
            set_border(con, "none")
        else:
            set_border(con, "pixel")


def on_window_new(conn, event) -> None:
    time.sleep(0.08)
    tree = conn.get_tree()
    con = find_by_id(tree, event.container.id) or event.container
    if not is_window(con):
        return

    # Auto-maximize only on window::new so that swayfx-maximize restores
    # are not re-maximized by the window::floating event they trigger.
    if should_auto_maximize(con) and not has_mark(con, MAXIMIZE_MARK):
        maximize_window(conn, con)
        # Brave reconfigures its surface ~0.5s into startup, which can
        # displace the freshly maximized window; re-anchor once settled.
        time.sleep(0.6)
        settled = find_by_id(conn.get_tree(), event.container.id)
        if settled is not None and has_mark(settled, MAXIMIZE_MARK):
            maximize_window(conn, settled)
        update_borders(conn)
        return

    update_borders(conn, tree=tree)


def on_window_floating(conn, event) -> None:
    # Placement lives here; auto-maximize does NOT — firing it here would
    # re-maximize the browser whenever swayfx-maximize issues 'floating enable'.
    time.sleep(0.08)
    tree = conn.get_tree()
    con = find_by_id(tree, event.container.id) or event.container
    if not is_window(con) or not is_floating(con):
        return
    if not has_mark(con, MAXIMIZE_MARK) and not is_dialog(con):
        place_floating_window(conn, con)
    update_borders(conn, tree=tree)


def on_focus(conn, event) -> None:
    # Always raise on focus — the is_floating check on event.container
    # can be stale; raising a tiled window is a safe no-op in Sway.
    try:
        event.container.command("raise")
    except Exception:
        pass
    update_borders(conn)


def on_fullscreen_mode(conn, event) -> None:
    con = event.container
    if getattr(con, "fullscreen_mode", 0):
        try:
            con.command("raise")
        except Exception:
            pass
    update_borders(conn)


def on_layout_event(conn, _event) -> None:
    update_borders(conn)


def main() -> int:
    conn = i3ipc.Connection()
    conn.on("window::new", on_window_new)
    conn.on("window::floating", on_window_floating)
    conn.on("window::focus", on_focus)
    conn.on("window::fullscreen_mode", on_fullscreen_mode)
    # window::move was dropped from the triggers: it duplicated the focus
    # event in practice and each handler costs a full get_tree round-trip.
    for event_name in (
        "window::close",
        "workspace::focus",
    ):
        conn.on(event_name, on_layout_event)

    update_borders(conn)
    conn.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
