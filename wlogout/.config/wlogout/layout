{
  "label": "lock",
  "action": "swaylock -f",
  "text": "BLOQUEAR",
  "keybind": "l",
}
{
  "label": "logout",
  "action": "swaymsg exit",
  "text": "SALIR",
  "keybind": "e",
}
{
  "label": "reboot",
  "action": "systemctl reboot",
  "text": "REINICIAR",
  "keybind": "r",
}
{
  "label": "shutdown",
  "action": "systemctl poweroff",
  "text": "APAGAR",
  "keybind": "p",
}