#!/usr/bin/env bash
# Verified against: waybar-custom(5), makoctl(1) — mako 1.11 plain-text list
# Reviewed: 2026-06-10

set -euo pipefail
IFS=$'\n\t'

json() {
    printf '{"text":"%s","class":"%s","tooltip":"%s"}\n' "$1" "$2" "$3"
}

notification_count() {
    local list count

    # mako >= 1.10 dropped JSON output: `makoctl list` prints plain text
    # with one "Notification <id>: <summary>" header per entry.
    list="$(makoctl list 2>/dev/null || true)"
    [[ -n "$list" ]] || {
        printf '0'
        return 0
    }

    count="$(grep -cE '^Notification [0-9]+:' <<< "$list" 2>/dev/null || true)"
    printf '%s' "${count:-0}"
}

if ! command -v makoctl >/dev/null 2>&1; then
    json "\\uf0f3" "off" "makoctl no esta disponible"
    exit 0
fi

modes="$(makoctl mode 2>/dev/null || true)"

if printf '%s\n' "$modes" | grep -qx 'do-not-disturb'; then
    json "\\uf1f6" "dnd" "No molestar activado"
else
    count="$(notification_count)"
    if [[ "$count" =~ ^[0-9]+$ && "$count" -gt 0 ]]; then
        json "\\uf0f3 $count" "has-notifications" "$count notificaciones"
    else
        json "\\uf0f3" "default" "Sin notificaciones pendientes"
    fi
fi
