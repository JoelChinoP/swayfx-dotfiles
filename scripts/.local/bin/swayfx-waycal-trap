#!/usr/bin/env python3
"""Transparent overlay that closes waycal on any click outside it.

waycal is a wlr-layer-shell TOP surface — above all regular floating
windows. This window covers the full output so any click that does NOT
land on waycal's area lands here instead, dismissing the calendar.
Focus reverts automatically to the previously focused window when this
window closes (Sway's normal focus-stack behaviour).
"""
import gi
import subprocess

gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib


class WaycalTrap(Gtk.Application):
    def __init__(self):
        super().__init__(application_id='swayfx.waycal.trap')

    def do_activate(self):
        win = Gtk.ApplicationWindow(application=self)
        win.set_decorated(False)
        win.set_skip_taskbar_hint(True)

        screen = win.get_screen()
        visual = screen.get_rgba_visual()
        if visual:
            win.set_visual(visual)
        win.set_app_paintable(True)
        win.resize(screen.get_width(), screen.get_height())

        win.connect('draw', self._draw)
        win.connect('button-press-event', self._click)
        win.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
        win.show_all()

        # Exit if waycal is closed by other means (Escape, toggle).
        GLib.timeout_add(400, self._poll)

    @staticmethod
    def _draw(_, cr):
        cr.set_source_rgba(0, 0, 0, 0)
        cr.paint()

    def _click(self, *_):
        subprocess.run(['pkill', '-x', 'waycal'], check=False)
        self.quit()

    def _poll(self):
        alive = subprocess.run(
            ['pgrep', '-x', 'waycal'], capture_output=True
        ).returncode == 0
        if not alive:
            self.quit()
            return GLib.SOURCE_REMOVE
        return GLib.SOURCE_CONTINUE


WaycalTrap().run()
