#!/usr/bin/env bash
# Toggle waycal from Waybar and close it when Sway focus changes.
#
# Verified against: https://github.com/forrestknight/waycal, swaymsg(1)
# Reviewed: 2026-05-14

set -euo pipefail
IFS=$'\n\t'

if pgrep -x waycal >/dev/null 2>&1; then
    pkill -x waycal
    exit 0
fi

command -v waycal >/dev/null 2>&1 || exit 127

waycal >/dev/null 2>&1 &
disown

command -v swaymsg >/dev/null 2>&1 || exit 0

# Transparent click-trap overlay (requires python3-gi, available on any
# system with GNOME apps installed).  The trap sits below waycal's
# layer-shell TOP surface so clicks on waycal still reach waycal; clicks
# anywhere else land here and dismiss the calendar.  When the trap closes,
# Sway automatically returns focus to the previously focused window — no
# second click needed.
if command -v swayfx-waycal-trap >/dev/null 2>&1; then
    swayfx-waycal-trap >/dev/null 2>&1 &
    disown
fi

# IPC fallback: closes waycal when the user switches workspaces (the trap
# stays on its origin workspace and can't catch that).  Also handles the
# case where python3-gi is unavailable.
(
    pgrep -x waycal >/dev/null 2>&1 || exit 0
    start_ns=$(date +%s%N)
    swaymsg -t subscribe '["window","workspace"]' 2>/dev/null |
        while IFS= read -r line; do
            pgrep -x waycal >/dev/null 2>&1 || exit 0
            elapsed_ms=$(( ( $(date +%s%N) - start_ns ) / 1000000 ))
            [[ $elapsed_ms -lt 600 ]] && continue
            if printf '%s' "$line" | grep -q '"change":"focus"'; then
                pkill -x waycal
                exit 0
            fi
        done
) >/dev/null 2>&1 &
disown
