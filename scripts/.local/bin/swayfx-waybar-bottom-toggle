#!/usr/bin/env bash
# Toggle the bottom Waybar dock (kill if running, start if not).
#
# Reviewed: 2026-05-13

set -euo pipefail
IFS=$'\n\t'

config="$HOME/.config/waybar/bottom.jsonc"
style="$HOME/.config/waybar/bottom.css"

if pgrep -f "waybar.*bottom\.jsonc" > /dev/null 2>&1; then
    pkill -f "waybar.*bottom\.jsonc"
else
    nohup waybar -c "$config" -s "$style" > /dev/null 2>&1 &
    disown
fi
