#!/usr/bin/env bash
# Toggle "ventana completa": tile the focused window so it fills the
# whole area below the top bar (no drag, real xdg maximized state so
# CSD clients like Brave drop their own borders), or restore it to a
# centered 1000x600 floating window.
#
# Verified against: swaymsg(1), sway-ipc(7)
# Reviewed: 2026-06-10

set -euo pipefail
IFS=$'\n\t'

RESTORE_WIDTH=1000
RESTORE_HEIGHT=600
RESTORE_BORDER=3
MARK_NAME="maximize"

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        printf 'missing command: %s\n' "$1" >&2
        exit 127
    }
}

require_cmd swaymsg
require_cmd jq

focused_json="$(
    swaymsg -t get_tree |
        jq -c 'recurse(.nodes[]?, .floating_nodes[]?) | select(.focused == true)' |
        tail -n 1
)"

if [[ -z "$focused_json" ]]; then
    exit 0
fi

con_id="$(jq -r '.id' <<< "$focused_json")"

if jq -e --arg mark "$MARK_NAME" '(.marks // []) | index($mark)' <<< "$focused_json" >/dev/null; then
    swaymsg "[con_id=$con_id] floating enable, unmark $MARK_NAME, border pixel $RESTORE_BORDER, shadows enable, resize set $RESTORE_WIDTH $RESTORE_HEIGHT, move position center" >/dev/null
    swaymsg "[con_id=$con_id] raise" >/dev/null 2>&1 || true
    exit 0
fi

# Floating is this desktop's natural state: any other tiled window in
# the focused workspace is a leftover (or a previously maximized one).
# Restore them so the new window owns the whole tiling area.
swaymsg -t get_tree | jq -r --argjson self "$con_id" '
    [recurse(.nodes[]?) | select(.type? == "workspace")
     | select([recurse(.nodes[]?, .floating_nodes[]?) | select(.focused? == true)] | length > 0)]
    | .[0] // empty
    | [recurse(.nodes[]?) | select((.app_id? != null) or (.window? != null)) | .id]
    | .[] | select(. != $self)' |
while IFS= read -r other_id; do
    swaymsg "[con_id=$other_id] floating enable, unmark $MARK_NAME, border pixel $RESTORE_BORDER, shadows enable, resize set $RESTORE_WIDTH $RESTORE_HEIGHT" >/dev/null 2>&1 || true
done

# Tiling does the real maximizing: with smart_gaps the lone tiled window
# fills the workspace and floating windows stay above it.
swaymsg "[con_id=$con_id] mark --add $MARK_NAME, floating disable, border none, shadows disable" >/dev/null
