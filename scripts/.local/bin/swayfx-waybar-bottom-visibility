#!/usr/bin/env bash
# Dynamically switch the bottom Waybar between dock and autohide.
#
# Reviewed: 2026-05-13

set -euo pipefail
IFS=$'\n\t'

runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
lock="$runtime_dir/swayfx-waybar-bottom-visibility.lock"

mkdir -p "$runtime_dir"
exec 9>"$lock"
flock -n 9 || exit 0

last_mode=""

focused_is_fullscreen() {
    swaymsg -t get_tree 2>/dev/null |
        jq -e '.. | objects | select(.focused? == true) | select((.fullscreen_mode? // 0) != 0)' >/dev/null
}

set_bottom_mode() {
    local mode="$1"
    local current_mode=""

    current_mode="$(
        swaymsg -t get_bar_config swayfx-bottom 2>/dev/null |
            jq -r '.mode // empty' 2>/dev/null || true
    )"

    if [[ "$mode" == "$current_mode" ]]; then
        last_mode="$mode"
        return 0
    fi

    if swaymsg bar swayfx-bottom mode "$mode" >/dev/null 2>&1; then
        last_mode="$mode"
        return 0
    fi

    # Fallback for Waybar builds that do not honor sway bar IPC.
    [[ "$mode" == "$last_mode" ]] && return 0
    local signal="USR2"
    [[ "$mode" == "hide" ]] && signal="USR1"
    pgrep -u "$(id -u)" -f 'waybar .*bottom\.jsonc' |
        xargs -r kill -s "$signal" 2>/dev/null || true
    last_mode="$mode"
}

update_visibility() {
    if focused_is_fullscreen; then
        set_bottom_mode hide
    else
        set_bottom_mode dock
    fi
}

while :; do
    update_visibility
    sleep 1
done
