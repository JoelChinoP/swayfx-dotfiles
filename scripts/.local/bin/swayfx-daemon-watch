#!/usr/bin/env bash
# Restart a user daemon if it exits, without spawning duplicates on reload.
#
# Verified against: flock(1)
# Reviewed: 2026-05-14

set -euo pipefail
IFS=$'\n\t'

daemon="${1:?usage: swayfx-daemon-watch <daemon-path> [args...]}"
shift
name="$(basename "$daemon")"
runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
lock_file="$runtime_dir/${name}.lock"

exec 9>"$lock_file"
flock -n 9 || exit 0

# Exponential backoff so a permanently crashing daemon cannot busy-loop
# at 1 restart/s; a run that survives >60s resets the delay.
delay=1
while true; do
    start="$(date +%s)"
    "$daemon" "$@" || true
    elapsed=$(( $(date +%s) - start ))

    if (( elapsed > 60 )); then
        delay=1
    else
        delay=$(( delay * 2 ))
        (( delay > 30 )) && delay=30
    fi
    sleep "$delay"
done
