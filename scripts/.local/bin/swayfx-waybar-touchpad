#!/usr/bin/env bash
# Emite JSON para el módulo custom/touchpad de waybar.
set -euo pipefail

swaymsg -t get_inputs 2>/dev/null | python3 -c "
import json, sys

data = json.load(sys.stdin)

has_mouse = any(
    d.get('type') == 'pointer'
    and bool(d.get('libinput'))
    and not any(kw in d.get('name', '').lower()
                for kw in ('trackpoint', 'virtual', 'pen', 'tablet', 'touch'))
    for d in data
)

tp = next((d for d in data if d.get('type') == 'touchpad'), None)

if tp is None:
    out = {'text': '', 'tooltip': 'Sin touchpad', 'class': 'absent'}
else:
    se = tp.get('libinput', {}).get('send_events', 'enabled')
    mouse = ' · Mouse conectado' if has_mouse else ''

    if se == 'enabled':
        out = {'text': '󰍽', 'tooltip': f'Touchpad activo{mouse} — clic: desactivar', 'class': 'on'}
    elif se == 'disabled':
        out = {'text': '󰍾', 'tooltip': f'Touchpad inactivo{mouse} — clic: activar', 'class': 'off'}
    else:
        if has_mouse:
            out = {'text': '󰍾', 'tooltip': 'Touchpad auto · Mouse conectado — clic: forzar activo', 'class': 'off'}
        else:
            out = {'text': '󰍽', 'tooltip': 'Touchpad auto · Sin mouse — clic: desactivar', 'class': 'on'}

print(json.dumps(out, ensure_ascii=False))
" 2>/dev/null || printf '{"text":"󰍽","tooltip":"Error","class":"on"}\n'
