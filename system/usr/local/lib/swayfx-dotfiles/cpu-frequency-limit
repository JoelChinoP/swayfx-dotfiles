#!/usr/bin/env bash
# Verified against: cpupower-frequency-set(1), Linux power_supply sysfs,
#                   amd-pstate EPP, ACPI platform_profile kernel docs, rfkill(8)
# Reviewed: 2026-06-14

set -euo pipefail
IFS=$'\n\t'

AC_MAX_KHZ="${AC_MAX_KHZ:-3000000}"
BATTERY_MAX_KHZ="${BATTERY_MAX_KHZ:-2000000}"

# amd-pstate-epp: the energy/performance preference lets the governor
# favor race-to-idle instead of relying only on the hard frequency cap.
# NOTE: the ASUS platform_profile handler derives its own EPP from the
# profile (balanced -> balance_power) and re-imposes it asynchronously,
# overriding contrary values; defaults below match that pairing so the
# config reflects effective behavior. apply_epp stays as best-effort
# reinforcement (battery: quiet + power agree).
AC_EPP="${AC_EPP:-balance_power}"
BATTERY_EPP="${BATTERY_EPP:-power}"
AC_PLATFORM_PROFILE="${AC_PLATFORM_PROFILE:-balanced}"
BATTERY_PLATFORM_PROFILE="${BATTERY_PLATFORM_PROFILE:-quiet}"
AC_BOOST="${AC_BOOST:-1}"
BATTERY_BOOST="${BATTERY_BOOST:-0}"

# Bluetooth: dropped on battery (no daily use here); restored on AC. Set both
# to "block" for always-off, or override via the service environment.
AC_BLUETOOTH="${AC_BLUETOOTH:-unblock}"
BATTERY_BLUETOOTH="${BATTERY_BLUETOOTH:-block}"

has_ac_power() {
    local supply type online

    for supply in /sys/class/power_supply/*; do
        [[ -r "$supply/type" && -r "$supply/online" ]] || continue
        type="$(< "$supply/type")"
        online="$(< "$supply/online")"

        # Avoid hardcoding AC adapter names. Any online non-battery
        # power_supply means the laptop is externally powered.
        if [[ "$type" != "Battery" && "$online" == "1" ]]; then
            return 0
        fi
    done

    return 1
}

apply_with_sysfs() {
    local max_khz="$1"
    local applied=0 file

    for file in /sys/devices/system/cpu/cpu[0-9]*/cpufreq/scaling_max_freq; do
        [[ -w "$file" ]] || continue
        printf '%s\n' "$max_khz" > "$file"
        applied=1
    done

    (( applied ))
}

apply_epp() {
    local epp="$1" applied=0 file

    for file in /sys/devices/system/cpu/cpu[0-9]*/cpufreq/energy_performance_preference; do
        [[ -w "$file" ]] || continue
        if printf '%s\n' "$epp" > "$file" 2>/dev/null; then
            applied=1
        fi
    done

    if (( applied )); then
        echo "Applied energy_performance_preference: $epp"
    fi
}

apply_platform_profile() {
    local prof="$1" node=/sys/firmware/acpi/platform_profile

    [[ -w "$node" ]] || return 0
    if ! grep -qw "$prof" "${node}_choices" 2>/dev/null; then
        return 0
    fi
    if printf '%s\n' "$prof" > "$node" 2>/dev/null; then
        echo "Applied platform_profile: $prof"
    fi
}

apply_boost() {
    local enabled="$1"
    local node=/sys/devices/system/cpu/cpufreq/boost
    [[ -w "$node" ]] || return 0
    printf '%s\n' "$enabled" > "$node"
    echo "Applied CPU boost: $enabled"
}

apply_usb_autosuspend() {
    local control="$1"
    local applied=0 dev

    for dev in /sys/bus/usb/devices/*/power/control; do
        [[ -w "$dev" ]] || continue
        printf '%s\n' "$control" > "$dev" 2>/dev/null || true
        applied=1
    done

    if [[ "$control" == "auto" ]]; then
        for dev in /sys/bus/usb/devices/*/power/autosuspend_delay_ms; do
            [[ -w "$dev" ]] || continue
            printf '2000\n' > "$dev" 2>/dev/null || true
        done
    fi

    (( applied )) && echo "Applied USB autosuspend: $control"
    return 0
}

apply_bluetooth() {
    local action="$1"

    command -v rfkill >/dev/null 2>&1 || return 0
    if rfkill "$action" bluetooth 2>/dev/null; then
        echo "Applied Bluetooth rfkill: $action"
    fi
}

if has_ac_power; then
    profile="AC"
    max_khz="$AC_MAX_KHZ"
    epp="$AC_EPP"
    platform_profile="$AC_PLATFORM_PROFILE"
    boost="$AC_BOOST"
    usb_control="on"
    bluetooth="$AC_BLUETOOTH"
else
    profile="battery"
    max_khz="$BATTERY_MAX_KHZ"
    epp="$BATTERY_EPP"
    platform_profile="$BATTERY_PLATFORM_PROFILE"
    boost="$BATTERY_BOOST"
    usb_control="auto"
    bluetooth="$BATTERY_BLUETOOTH"
fi

# platform_profile first: the ASUS ACPI handler rewrites the EPP when
# the profile changes, so the explicit EPP must be applied afterwards.
apply_platform_profile "$platform_profile"
apply_epp "$epp"
apply_boost "$boost"
apply_usb_autosuspend "$usb_control"
apply_bluetooth "$bluetooth"

if ! compgen -G '/sys/devices/system/cpu/cpu[0-9]*/cpufreq/scaling_max_freq' >/dev/null; then
    echo "No cpufreq scaling_max_freq files found; skipping CPU ceiling."
    exit 0
fi

if command -v cpupower >/dev/null 2>&1; then
    if cpupower frequency-set -u "${max_khz}kHz"; then
        echo "Applied $profile CPU frequency ceiling: ${max_khz} kHz"
        exit 0
    fi

    echo "cpupower failed; falling back to sysfs." >&2
fi

if apply_with_sysfs "$max_khz"; then
    echo "Applied $profile CPU frequency ceiling via sysfs: ${max_khz} kHz"
else
    echo "Failed to apply CPU frequency ceiling." >&2
    exit 1
fi
