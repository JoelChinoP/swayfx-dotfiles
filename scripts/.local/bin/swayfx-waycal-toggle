#!/usr/bin/env bash
# Toggle waycal from Waybar and close it when Sway focus changes.
#
# Verified against: https://github.com/forrestknight/waycal, swaymsg(1)
# Reviewed: 2026-05-14

set -euo pipefail
IFS=$'\n\t'

if pgrep -x waycal >/dev/null 2>&1; then
    pkill -x waycal
    exit 0
fi

command -v waycal >/dev/null 2>&1 || exit 127

waycal >/dev/null 2>&1 &
disown

command -v swaymsg >/dev/null 2>&1 || exit 0

(
    # Wait for waycal startup noise before monitoring focus changes.
    sleep 0.8
    pgrep -x waycal >/dev/null 2>&1 || exit 0

    # Close waycal on the first focus-change event (window or workspace).
    # Parse the event line directly — no swaymsg round-trips per event.
    swaymsg -t subscribe '["window","workspace"]' 2>/dev/null |
        while IFS= read -r line; do
            pgrep -x waycal >/dev/null 2>&1 || exit 0
            if printf '%s' "$line" | grep -q '"change":"focus"'; then
                pkill -x waycal
                exit 0
            fi
        done
) >/dev/null 2>&1 &
disown
