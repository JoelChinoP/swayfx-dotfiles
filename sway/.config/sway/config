# SwayFX desktop config.
#
# Verified against: https://github.com/WillPower3309/swayfx, sway(5)
# Reviewed: 2026-05-16

set $mod Mod4
set $term ghostty
set $launcher fuzzel
set $files nautilus
set $editor gnome-text-editor
set $browser swayfx-browser

# Pure-black palette.
set $bg          #000000
set $surface     #0e0e10
set $surface_alt #15151a
set $border      #1f1f24
set $text        #e6e6e6
set $text_dim    #9a9aa6
set $accent      #89b4fa
set $focus_border #ffffaa
set $ok          #a6e3a1
set $warn        #f9e2af
set $crit        #f38ba8

font pango:Inter 14

client.focused           $focus_border $bg $text $focus_border $focus_border
client.focused_inactive  $border  $bg $text $border $border
client.unfocused         $surface $bg $text $surface $surface
client.urgent            $crit    $bg $text $crit $crit

# SwayFX visuals.
default_border pixel 3
smart_borders no
default_floating_border pixel 3
floating_modifier $mod normal
focus_follows_mouse no
focus_on_window_activation focus
gaps inner 6
gaps horizontal 1
gaps vertical 1
# smart_gaps on
smart_gaps off
corner_radius 10
shadows disable
default_dim_inactive 0.05
dim_inactive_colors.unfocused #000000FF

# Floating windows keep subtle depth; maximized windows disable shadows.
for_window [floating] shadows enable, shadow_blur_radius 20, shadow_color #00000060

# DEVIATION: wlogout uses layer blur to make the power menu feel modal.
# The rest of the layer-shell UI stays unblurred.
layer_effects "wlogout" {
    blur enable
    blur_passes 3
    blur_radius 6
    shadows disable
}

# Blur only on the terminal.
blur disable
for_window [app_id="com.mitchellh.ghostty"] blur enable, blur_passes 3, blur_radius 5, opacity set 0.85

# Keep graphics/video apps color-accurate.
for_window [app_id="^gimp.*$"] blur disable, opacity set 1.0
for_window [class="^krita.*$"] blur disable, opacity set 1.0
for_window [app_id="org.inkscape.Inkscape"] blur disable, opacity set 1.0
for_window [app_id="com.obsproject.Studio"] blur disable, opacity set 1.0
for_window [app_id="virt-manager"] blur disable, opacity set 1.0
for_window [app_id="mpv"] blur disable, opacity set 1.0

# DEVIATION: SwayFX upstream marks scratchpad_minimize as experimental.
# It is enabled because the project explicitly wants desktop-like
# minimize behavior. If restore quirks appear, disable it and rely on
# wlr/taskbar raise/lower.
scratchpad_minimize enable

# Input. Adjust with `swaymsg -t get_inputs` if the laptop keyboard uses
# a different layout.
input type:keyboard {
    xkb_layout latam,us
    xkb_options grp:alt_shift_toggle
}

input type:touchpad {
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
    dwt enabled
    events disabled_on_external_mouse
}

# Outputs are intentionally not hardcoded.
# Discover with: swaymsg -t get_outputs
output * bg ~/.config/sway/wallpaper.png fill

# Environment for dbus/systemd-activated apps.
exec_always dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE XDG_SESSION_DESKTOP
exec_always systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE XDG_SESSION_DESKTOP

# Core autostart.
exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec mako
exec nm-applet --indicator
exec blueman-applet
exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store
exec gammastep
exec_always ~/.local/bin/swayfx-daemon-watch ~/.local/bin/swayfx-refresh-rate --watch

# Idle and lock.
exec swayidle -w timeout 300 'swaylock -f' timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' before-sleep 'swaylock -f'

# Two Waybar instances.
exec_always sh -lc 'export PATH="$HOME/.local/bin:$PATH"; pkill -x waybar || true; waybar -c "$HOME/.config/waybar/top.jsonc" -s "$HOME/.config/waybar/top.css" & waybar -c "$HOME/.config/waybar/bottom.jsonc" -s "$HOME/.config/waybar/bottom.css" &'

# Refresca módulo touchpad de waybar tras arranque completo (evita estado desactualizado).
exec_always bash -c 'sleep 2 && kill -SIGRTMIN+4 $(pgrep -x waybar) 2>/dev/null || true'

# Floating placement and border policy.
exec_always ~/.local/bin/swayfx-daemon-watch ~/.local/bin/swayfx-placement-daemon

# Application launchers.
# --release Super_L solo dispara cuando Super se suelta sin combinar con otra tecla.
bindsym --release Super_L exec bash -c 'pgrep -x fuzzel >/dev/null 2>&1 && pkill -x fuzzel || fuzzel'
# bindsym $mod+d             exec bash -c 'pgrep -x fuzzel >/dev/null 2>&1 && pkill -x fuzzel || fuzzel'
bindsym $mod+Return exec $term
bindsym $mod+Shift+e exec $files
bindsym $mod+Shift+t exec $editor
bindsym $mod+b exec $browser

# Desktop-like actions.
bindsym $mod+q kill
bindsym $mod+Shift+f fullscreen toggle
bindsym $mod+f exec ~/.local/bin/swayfx-maximize
bindsym $mod+Shift+space floating toggle
bindsym $mod+m move scratchpad
bindsym $mod+Shift+m scratchpad show

# Focus.
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move windows.
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Layouts and splits.
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+v splitv
bindsym $mod+c splith

# Workspaces.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Teclado numerico.
bindsym $mod+KP_1 workspace number $ws1
bindsym $mod+KP_2 workspace number $ws2
bindsym $mod+KP_3 workspace number $ws3
bindsym $mod+KP_4 workspace number $ws4
bindsym $mod+KP_5 workspace number $ws5
bindsym $mod+KP_6 workspace number $ws6
bindsym $mod+KP_7 workspace number $ws7
bindsym $mod+KP_8 workspace number $ws8
bindsym $mod+KP_9 workspace number $ws9
bindsym $mod+KP_0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+Shift+KP_1 move container to workspace number $ws1
bindsym $mod+Shift+KP_2 move container to workspace number $ws2
bindsym $mod+Shift+KP_3 move container to workspace number $ws3
bindsym $mod+Shift+KP_4 move container to workspace number $ws4
bindsym $mod+Shift+KP_5 move container to workspace number $ws5
bindsym $mod+Shift+KP_6 move container to workspace number $ws6
bindsym $mod+Shift+KP_7 move container to workspace number $ws7
bindsym $mod+Shift+KP_8 move container to workspace number $ws8
bindsym $mod+Shift+KP_9 move container to workspace number $ws9
bindsym $mod+Shift+KP_0 move container to workspace number $ws10

bindsym $mod+Shift+KP_End move container to workspace number $ws1
bindsym $mod+Shift+KP_Down move container to workspace number $ws2
bindsym $mod+Shift+KP_Next move container to workspace number $ws3
bindsym $mod+Shift+KP_Left move container to workspace number $ws4
bindsym $mod+Shift+KP_Begin move container to workspace number $ws5
bindsym $mod+Shift+KP_Right move container to workspace number $ws6
bindsym $mod+Shift+KP_Home move container to workspace number $ws7
bindsym $mod+Shift+KP_Up move container to workspace number $ws8
bindsym $mod+Shift+KP_Prior move container to workspace number $ws9
bindsym $mod+Shift+KP_Insert move container to workspace number $ws10


# Workspaces — navegar por dirección.
bindsym $mod+Ctrl+Right workspace next
bindsym $mod+Ctrl+Left  workspace prev
bindsym $mod+Tab        workspace back_and_forth

# Super+Scroll cambia workspace sobre cualquier ventana.
bindsym --whole-window $mod+button4 workspace prev
bindsym --whole-window $mod+button5 workspace next

# Gestos touchpad: 3 dedos izquierda/derecha cambian workspace.
bindgesture swipe:3:left  workspace next
bindgesture swipe:3:right workspace prev

# Utilities.
bindsym $mod+Ctrl+l exec swaylock -f
bindsym $mod+Ctrl+v exec ~/.local/bin/swayfx-cliphist-menu
bindsym $mod+n exec nmgui
bindsym $mod+Shift+b exec ~/.local/bin/swayfx-waybar-bottom-toggle
bindsym Print exec ~/.local/bin/swayfx-screenshot full
bindsym $mod+Print exec ~/.local/bin/swayfx-screenshot area
bindsym $mod+Shift+Print exec ~/.local/bin/swayfx-screenshot edit
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym XF86TouchpadToggle exec ~/.local/bin/swayfx-touchpad-toggle
bindsym XF86TouchpadOn     exec bash -c 'swaymsg input type:touchpad events enabled;  kill -SIGRTMIN+4 $(pgrep -x waybar) 2>/dev/null || true'
bindsym XF86TouchpadOff    exec bash -c 'swaymsg input type:touchpad events disabled; kill -SIGRTMIN+4 $(pgrep -x waybar) 2>/dev/null || true'
bindsym $mod+p exec ~/.local/bin/swayfx-touchpad-toggle
bindsym $mod+g exec ~/.local/bin/swayfx-gammastep-toggle
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+q exec ~/.local/bin/swayfx-powermenu

# Floating rules.
for_window [app_id=".*"] floating enable, resize set 1000 600
for_window [class=".*"] floating enable, resize set 1000 600

# Brave Origin opens floating like every other app; the placement daemon
# auto-maximizes it below the waybar. Use browser F11 for true fullscreen.
# Z-order with other floating windows is handled by the daemon's raise-on-focus.

for_window [window_type="dialog"] floating enable
for_window [window_role="pop-up"] floating enable
for_window [app_id="pavucontrol"] floating enable, resize set 780 520
for_window [app_id="nm-connection-editor"] floating enable, resize set 780 560
for_window [app_id="blueman-manager"] floating enable, resize set 820 560
for_window [app_id="gnome-calculator"] floating enable resize set 700 300
for_window [app_id="org.gnome.Calculator"] floating enable
for_window [app_id="org.gnome.Loupe"] floating enable
for_window [app_id="org.gnome.FileRoller"] floating enable
for_window [title="Picture-in-Picture"] floating enable, sticky enable

# waycal click-trap overlay: fullscreen transparent, no chrome, excluded
# from cascade placement via the maximize mark so the daemon ignores it.
for_window [app_id="swayfx.waycal.trap"] floating enable, mark --add maximize, border none, shadows disable, blur disable, opacity set 1.0, move position 0 0
