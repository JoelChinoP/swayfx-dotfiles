# Ghostty config.
#
# Verified against: https://ghostty.org/docs/config/reference
# Reviewed: 2026-05-13

font-family = "FiraCode Nerd Font Mono"
font-size = 14
window-padding-x = 4
window-padding-y = 4

background = #000000
foreground = #e6e6e6
background-opacity = 1.0
cursor-color = #89b4fa
selection-background = #15151a
selection-foreground = #e6e6e6

gtk-single-instance = true
window-decoration = client
confirm-close-surface = false
copy-on-select = clipboard
