#!/usr/bin/env bash
# Toggle de 2 estados basado en estado efectivo: activoâ†’desactiva, inactivoâ†’activa.
# "auto" (disabled_on_external_mouse) cuenta como OFF cuando hay mouse externo.
set -euo pipefail

effective=$(swaymsg -t get_inputs 2>/dev/null | python3 -c "
import json, sys
data = json.load(sys.stdin)
has_mouse = any(
    d.get('type') == 'pointer'
    and bool(d.get('libinput'))
    and not any(kw in d.get('name', '').lower()
                for kw in ('trackpoint', 'virtual', 'pen', 'tablet', 'touch'))
    for d in data
)
for d in data:
    if d.get('type') == 'touchpad':
        se = d.get('libinput', {}).get('send_events', 'enabled')
        if se == 'enabled':
            print('on')
        elif se == 'disabled':
            print('off')
        else:
            print('off' if has_mouse else 'on')
        break
else:
    print('none')
" 2>/dev/null || echo none)

case "$effective" in
    none) exit 0 ;;
    on)   swaymsg input type:touchpad events disabled ;;
    off)  swaymsg input type:touchpad events enabled ;;
esac

kill -SIGRTMIN+4 $(pgrep -x waybar) 2>/dev/null || true
