anchor=top-right
margin=10

width=320
height=110
padding=12

background-color=#000000ee
text-color=#e8e8e8
border-size=1
border-color=#f3e2a744
border-radius=12

font=JetBrainsMono Nerd Font 11
icons=1
icon-path=/usr/share/icons/Papirus-Dark
max-icon-size=36

default-timeout=5000
ignore-timeout=0

format=<b>%s</b>\n%b
markup=1

[urgency=low]
background-color=#000000dd
border-color=#2b2b2b

[urgency=high]
background-color=#000000ee
border-color=#f38ba8cc
text-color=#f38ba8
default-timeout=0
