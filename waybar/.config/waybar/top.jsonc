// Verified against: waybar(5), waybar-clock(5), waybar-sway-workspaces(5)
// Reviewed: 2026-05-14
{
  "name": "top",
  "layer": "top",
  "position": "top",
  "fixed-center": true,
  "expand-left": true,
  "expand-right": true,
  "height": 32,
  "spacing": 0,
  "modules-left": [
    "custom/distro",
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "network",
    "pulseaudio",
    "battery",
    "custom/cpucap",
    "custom/notifications",
    "custom/power"
  ],
  "custom/distro": {
    "format": "َ°£‡",
    "tooltip": false,
    "on-click": "fuzzel"
  },
  "sway/workspaces": {
    "format": "{name}",
    "disable-scroll": true
  },
  "sway/mode": {
    "format": "َ°¨‘ {}",
    "tooltip": false
  },
  "clock": {
    // Left click opens waycal. Hover calendar is disabled intentionally.
    "format": "<b>{:%H:%M}</b>",
    "format-alt": "<b>{:%A, %d %B %Y}</b>",
    "locale": "es_PE.utf8",
    "tooltip": false,
    "on-click": "bash ~/.local/bin/swayfx-waycal-toggle",
    "actions": {
      // Right click toggles hour/date.
      "on-click-right": "mode"
    }
  },
  "network": {
    "format-wifi": "َ°¤¨ {signalStrength}%",
    "format-ethernet": "َ°ˆ€ {ifname}",
    "format-linked": "َ°ˆ€ (sin IP)",
    "format-disconnected": "َ°¤­",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)  {ipaddr}",
    "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Desconectado",
    "on-click": "nmgui",
    "on-click-right": "nm-connection-editor"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں",
    "format-icons": [
      "َ°•؟",
      "َ°–€",
      "َ°•¾"
    ],
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}% ({time})",
    "format-plugged": "َ°ڑ¥ {capacity}%",
    "format-time": "{H}h {M}m",
    "tooltip-format": "{timeTo} â€” {power:.1f}W",
    "format-icons": [
      "َ°پ؛",
      "َ°پ»",
      "َ°پ¼",
      "َ°پ½",
      "َ°پ¾",
      "َ°پ؟",
      "َ°‚€",
      "َ°‚پ",
      "َ°‚‚",
      "َ°پ¹"
    ],
    "states": {
      "warning": 30,
      "critical": 15
    }
  },
  "custom/cpucap": {
    "exec": "bash ~/.local/bin/swayfx-cpu-cap",
    "return-type": "json",
    "interval": 10
  },
  "custom/notifications": {
    "exec": "bash ~/.local/bin/swayfx-waybar-notifications",
    "return-type": "json",
    "interval": 5,
    "signal": 1,
    "on-click": "makoctl dismiss --all",
    "on-click-right": "makoctl mode -t do-not-disturb"
  },
  "custom/power": {
    "format": "َ°گ¥",
    "tooltip": false,
    "on-click": "bash ~/.local/bin/swayfx-powermenu"
  }
}
