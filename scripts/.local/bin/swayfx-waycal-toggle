#!/usr/bin/env bash
# Toggle waycal from Waybar and close it when Sway focus changes.
#
# Verified against: https://github.com/forrestknight/waycal, swaymsg(1)
# Reviewed: 2026-05-14

set -euo pipefail
IFS=$'\n\t'

if pgrep -x waycal >/dev/null 2>&1; then
    pkill -x waycal
    exit 0
fi

command -v waycal >/dev/null 2>&1 || exit 127

waycal >/dev/null 2>&1 &
disown

command -v swaymsg >/dev/null 2>&1 || exit 0

(
    pgrep -x waycal >/dev/null 2>&1 || exit 0

    # Subscribe immediately so no click event is missed.
    # Discard events in the first 600 ms — the opening click and waycal's
    # initial focus grab would otherwise close the calendar at once.
    start_ns=$(date +%s%N)
    swaymsg -t subscribe '["window","workspace"]' 2>/dev/null |
        while IFS= read -r line; do
            pgrep -x waycal >/dev/null 2>&1 || exit 0
            elapsed_ms=$(( ( $(date +%s%N) - start_ns ) / 1000000 ))
            [[ $elapsed_ms -lt 600 ]] && continue
            if printf '%s' "$line" | grep -q '"change":"focus"'; then
                pkill -x waycal
                exit 0
            fi
        done
) >/dev/null 2>&1 &
disown
