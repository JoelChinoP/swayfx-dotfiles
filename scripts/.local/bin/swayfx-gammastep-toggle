#!/usr/bin/env bash
# Habilita o deshabilita gammastep y notifica a waybar para actualizar el icono.
set -euo pipefail

if pgrep -x gammastep >/dev/null 2>&1; then
    pkill -x gammastep
else
    gammastep >/dev/null 2>&1 &
    disown
fi

# Espera breve para que gammastep arranque/muera antes de que waybar consulte su estado.
sleep 0.15

# SIGRTMIN+3 actualiza el módulo custom/gammastep.
# kill con pgrep es más fiable que pkill para señales RTMIN en bash.
kill -SIGRTMIN+3 $(pgrep -x waybar) 2>/dev/null || true
