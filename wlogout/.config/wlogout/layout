{
  "label": "lock",
  "action": "swaylock -f",
  "text": "Bloquear",
  "keybind": "l"
}
{
  "label": "logout",
  "action": "swaymsg exit",
  "text": "Salir",
  "keybind": "e"
}
{
  "label": "reboot",
  "action": "systemctl reboot",
  "text": "Reiniciar",
  "keybind": "r"
}
{
  "label": "shutdown",
  "action": "systemctl poweroff",
  "text": "Apagar",
  "keybind": "p"
}
