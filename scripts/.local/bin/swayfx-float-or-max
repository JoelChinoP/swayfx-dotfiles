#!/usr/bin/env bash
# $mod+Shift+space dispatcher: Brave toggles window-maximize (full window
# below the top bar, never xdg fullscreen); everything else keeps the
# classic floating toggle.
#
# Verified against: swaymsg(1), sway-ipc(7)
# Reviewed: 2026-06-10

set -euo pipefail
IFS=$'\n\t'

command -v swaymsg >/dev/null 2>&1 || exit 127
command -v jq >/dev/null 2>&1 || exit 127

app_id="$(
    swaymsg -t get_tree |
        jq -r 'recurse(.nodes[]?, .floating_nodes[]?)
               | select(.focused == true)
               | (.app_id // .window_properties.class // "")' |
        tail -n 1 | tr '[:upper:]' '[:lower:]'
)"

case "$app_id" in
    brave*)
        exec "$HOME/.local/bin/swayfx-maximize"
        ;;
    *)
        exec swaymsg floating toggle
        ;;
esac
