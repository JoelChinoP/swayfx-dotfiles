# swayidle
# 5 min: baja brillo
# 10 min: bloquea
# 11 min: apaga panel

timeout 300 'brightnessctl -s set 20%' \
  resume 'brightnessctl -r'

timeout 600 '~/.config/sway/scripts/lock.sh'

timeout 660 'swaymsg "output * dpms off"' \
  resume 'swaymsg "output * dpms on"'

before-sleep '~/.config/sway/scripts/lock.sh'
